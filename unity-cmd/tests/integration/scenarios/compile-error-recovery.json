{
  "name": "compile-error-recovery",
  "description": "Inject a C# syntax error → compile → verify errors → delete file → recompile → verify recovery",
  "steps": [
    {
      "name": "00_ping_before",
      "command": "ping",
      "timeoutMs": 20000,
      "expect": { "ok": true },
      "expectConnectorBuild": 39
    },

    {
      "name": "01_baseline_compile",
      "command": "compile",
      "timeoutMs": 30000,
      "expect": { "ok": true }
    },

    {
      "name": "02_state_edit_before",
      "command": "state",
      "expect": {
        "ok": true,
        "data": { "is_playing": false },
        "dataHas": ["connector_state", "commands_ready", "is_compiling"]
      }
    },

    {
      "name": "03_write_bad_cs",
      "writeFile": {
        "path": "${UNITY_CMD_WORKSPACE}/Assets/_IntegrationTest_CompileErrorRecovery.cs",
        "content": "// AUTO-GENERATED by compile-error-recovery integration test — DO NOT COMMIT\nclass _IntegrationTest_CompileErrorRecovery { SYNTAX ERROR HERE }\n"
      }
    },

    {
      "name": "04_sleep_for_import",
      "sleepMs": 2000
    },

    {
      "name": "05_compile_with_syntax_error",
      "command": "compile",
      "expect": { "ok": true }
    },

    {
      "name": "06_console_has_compile_errors",
      "command": "console",
      "args": ["--type", "error", "--lines", "30"],
      "expect": { "ok": true, "dataHas": ["count", "entries"] }
    },

    {
      "name": "07_delete_bad_cs",
      "deleteFile": {
        "path": "${UNITY_CMD_WORKSPACE}/Assets/_IntegrationTest_CompileErrorRecovery.cs"
      }
    },

    {
      "name": "08_sleep_for_reimport",
      "sleepMs": 2000
    },

    {
      "name": "09_recompile_after_fix",
      "command": "compile",
      "expect": { "ok": true }
    },

    {
      "name": "10_state_edit_after_recovery",
      "command": "state",
      "expect": {
        "ok": true,
        "data": { "is_playing": false, "play_mode": "edit" },
        "dataHas": ["connector_state", "commands_ready", "is_compiling", "connector_build"]
      }
    },

    {
      "name": "11_ping_after_recovery",
      "command": "ping",
      "expect": { "ok": true }
    },

    {
      "name": "12_list_catalog_after_recovery",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": ["compile", "echo", "ping", "state"],
        "forbiddenScopes": ["runtime"]
      }
    },

    {
      "name": "13_echo_after_recovery",
      "command": "echo",
      "expect": { "data": { "channel": "editor" } }
    }
  ]
}
