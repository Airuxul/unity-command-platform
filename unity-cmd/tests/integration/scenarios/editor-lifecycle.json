{
  "name": "editor-lifecycle",
  "description": "Editor edit mode tools â†?Play â†?editor_play runtime + editor screenshot/profiler â†?stop â†?edit mode again",
  "steps": [
    {
      "name": "00_force_stop_before_suite",
      "command": "stop",
      "timeoutMs": 90000,
      "expect": { "ok": true }
    },
    {
      "name": "00b_wait_after_forced_stop",
      "sleepMs": 1500
    },
    {
      "name": "01_ping_editor",
      "command": "ping",
      "expect": { "ok": true },
      "expectConnectorBuild": 23
    },
    {
      "name": "02_state_edit",
      "command": "state",
      "expect": {
        "ok": true,
        "data": { "is_playing": false },
        "dataHas": ["is_compiling", "connector_build", "ready_for_tools"]
      }
    },
    {
      "name": "03_list_catalog_edit",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": [
          "compile",
          "console",
          "echo",
          "exec",
          "ping",
          "play",
          "profiler",
          "screenshot",
          "state"
        ],
        "forbidden": ["echo.runtime"],
        "forbiddenScopes": ["runtime"]
      }
    },
    {
      "name": "04_echo_editor",
      "command": "echo",
      "expect": { "data": { "channel": "editor" } }
    },
    {
      "name": "05_console",
      "command": "console",
      "args": ["--type", "error,warning", "--lines", "5"],
      "expect": { "ok": true, "dataHas": ["count", "entries"] }
    },
    {
      "name": "06_profiler_status_edit",
      "command": "profiler",
      "args": ["--action", "status"],
      "expect": { "ok": true, "dataHas": ["enabled", "frame_count"] }
    },
    {
      "name": "07_profiler_enable",
      "command": "profiler",
      "args": ["--action", "enable"],
      "expect": { "ok": true, "dataHas": ["enabled"] }
    },
    {
      "name": "08_exec",
      "command": "exec",
      "args": ["--code", "return 1 + 1;"],
      "timeoutMs": 90000,
      "expect": { "ok": true, "dataHas": ["result"] }
    },
    {
      "name": "09_enter_play",
      "command": "play",
      "timeoutMs": 90000,
      "expect": { "ok": true }
    },
    {
      "name": "10_wait_editor_play_endpoint",
      "waitProfile": "editor-play",
      "timeoutMs": 45000
    },
    {
      "name": "11_echo_runtime",
      "hostKind": "editor_play",
      "command": "echo",
      "expect": { "data": { "channel": "runtime" } }
    },
    {
      "name": "12_ping_editor_play",
      "hostKind": "editor_play",
      "command": "ping",
      "expect": { "ok": true },
      "expectConnectorBuild": 23
    },
    {
      "name": "12b_reject_compile_on_editor_play",
      "hostKind": "editor_play",
      "command": "compile",
      "expectFailure": true
    },
    {
      "name": "13_list_catalog_editor_play",
      "hostKind": "editor_play",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": ["echo", "ping"],
        "forbidden": [
          "compile",
          "console",
          "echo.editor",
          "exec",
          "play",
          "profiler",
          "screenshot",
          "state"
        ],
        "forbiddenScopes": ["editor"]
      }
    },
    {
      "name": "14_list_catalog_editor_during_play",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": [
          "compile",
          "console",
          "ping",
          "play",
          "profiler",
          "screenshot",
          "state"
        ],
        "forbidden": ["echo.runtime"],
        "forbiddenScopes": ["runtime"]
      }
    },
    {
      "name": "15_state_during_play",
      "command": "state",
      "expect": { "ok": true, "data": { "is_playing": true } }
    },
    {
      "name": "16_profiler_status_during_play",
      "command": "profiler",
      "args": ["--action", "status"],
      "expect": { "ok": true, "dataHas": ["enabled", "frame_count", "is_playing"] }
    },
    {
      "name": "17_profiler_hierarchy_during_play",
      "command": "profiler",
      "args": [
        "--action",
        "hierarchy",
        "--frame",
        "-1",
        "--root",
        "PlayerLoop",
        "--max",
        "8",
        "--depth",
        "1"
      ],
      "expect": { "ok": true, "dataHas": ["mode", "frame", "children"] }
    },
    {
      "name": "17b_profiler_all_frames_during_play",
      "command": "profiler",
      "args": [
        "--action",
        "hierarchy",
        "--frames",
        "99999",
        "--root",
        "PlayerLoop",
        "--max",
        "128",
        "--depth",
        "2"
      ],
      "expect": { "ok": true, "dataHas": ["mode", "frame_count", "items"] }
    },
    {
      "name": "18_screenshot_game_via_editor_host",
      "hostKind": "editor",
      "command": "screenshot",
      "args": [
        "--view",
        "game",
        "--output_path",
        "${UNITY_CMD_CACHE_DIR}/integration-editor-lifecycle-play.png",
        "--width",
        "640",
        "--height",
        "360"
      ],
      "expect": { "ok": true, "dataHas": ["path", "width", "height"] }
    },
    {
      "name": "19_assert_screenshot_file",
      "assertFile": {
        "path": "${UNITY_CMD_CACHE_DIR}/integration-editor-lifecycle-play.png",
        "minBytes": 400
      }
    },
    {
      "name": "20_exit_play",
      "command": "stop",
      "timeoutMs": 90000,
      "expect": { "ok": true }
    },
    {
      "name": "21_wait_editor_after_stop",
      "sleepMs": 2000
    },
    {
      "name": "22_state_after_play",
      "command": "state",
      "expect": { "ok": true, "data": { "is_playing": false } }
    },
    {
      "name": "23_echo_editor_after_play",
      "command": "echo",
      "expect": { "data": { "channel": "editor" } }
    },
    {
      "name": "24_profiler_status_after_play",
      "command": "profiler",
      "args": ["--action", "status"],
      "expect": { "ok": true, "dataHas": ["enabled", "frame_count"] }
    },
    {
      "name": "25_list_catalog_edit_after_play",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": ["compile", "echo", "ping", "play"],
        "forbidden": ["echo.runtime"],
        "forbiddenScopes": ["runtime"]
      }
    }
  ]
}
